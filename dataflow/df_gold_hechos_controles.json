{
	"name": "df_gold_hechos_controles",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "BJA_silver_controles_prenatales",
						"type": "DatasetReference"
					},
					"name": "ImportarSupSilverControles"
				},
				{
					"dataset": {
						"referenceName": "BJA_silver_controles_pediatricos",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "SUP_silver_controles",
						"type": "DatasetReference"
					},
					"name": "source2"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "oro_Hechos_Controles",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "select1"
				},
				{
					"name": "select2"
				},
				{
					"name": "select3"
				},
				{
					"name": "union1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          control_prenatal_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          semana_gestacion as string,",
				"          peso_madre_kg as string,",
				"          presion_arterial as string,",
				"          resultado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> ImportarSupSilverControles",
				"source(output(",
				"          control_pediatrico_id as string,",
				"          ci_madre as string,",
				"          ci_recien_nacido as string,",
				"          establecimiento_id as string,",
				"          fecha_control as date,",
				"          peso as decimal(5,2),",
				"          talla as decimal(5,2)",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source(output(",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          nro_control as integer,",
				"          fecha_control as date,",
				"          semana_gestacion as integer,",
				"          peso_madre_kg as decimal(5,2),",
				"          presion_arterial as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source2",
				"ImportarSupSilverControles derive(control_id = concat('BJA_PRE_', toString(control_prenatal_id)),",
				"          programa = 'BJA',",
				"          tipo_control = 'PRENATAL',",
				"          ci_beneficiaria = ci_beneficiaria,",
				"          fecha_control = toDate(fecha_control),",
				"          nro_control = toInteger(nro_control),",
				"          semana_gestacion = toInteger(semana_gestacion),",
				"          peso_madre_kg = toDecimal(peso_madre_kg),",
				"          presion_arterial = presion_arterial,",
				"          resultado = resultado) ~> derivedColumn1",
				"source1 derive(control_id = concat('BJA_PED_', toString(control_pediatrico_id)),",
				"          programa = 'BJA'  ,",
				"          ci_beneficiaria = ci_madre,",
				"          fecha_control = fecha_control,",
				"          tipo_control = 'PEDIATRICO',",
				"          {peso_madre_kg } = peso,",
				"          nro_control = 0,",
				"          semana_gestacion = 0,",
				"          presion_arterial = '') ~> derivedColumn2",
				"source2 derive(control_id = concat('SUP_PRE_', toString(control_id)),",
				"          programa = 'SUP',",
				"          ci_beneficiaria = ci_beneficiaria,",
				"          fecha_control = fecha_control,",
				"          nro_control = nro_control,",
				"          semana_gestacion = semana_gestacion,",
				"          peso_madre_kg = peso_madre_kg,",
				"          presion_arterial = presion_arterial,",
				"          tipo_control = 'PRENATAL',",
				"          establecimiento_id = establecimiento_id) ~> derivedColumn3",
				"derivedColumn1 select(mapColumn(",
				"          control_id,",
				"          ci_beneficiaria,",
				"          establecimiento_id,",
				"          nro_control,",
				"          fecha_control,",
				"          semana_gestacion,",
				"          peso_madre_kg,",
				"          presion_arterial,",
				"          programa,",
				"          tipo_control",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"derivedColumn2 select(mapColumn(",
				"          control_id,",
				"          ci_beneficiaria,",
				"          ci_recien_nacido,",
				"          establecimiento_id,",
				"          fecha_control,",
				"          peso,",
				"          talla,",
				"          programa",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"derivedColumn3 select(mapColumn(",
				"          control_id,",
				"          ci_beneficiaria,",
				"          establecimiento_id,",
				"          nro_control,",
				"          fecha_control,",
				"          semana_gestacion,",
				"          peso_madre_kg,",
				"          presion_arterial,",
				"          programa",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"select1, select2, select3 union(byName: true)~> union1",
				"union1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          control_id as string,",
				"          persona_key as integer,",
				"          establecimiento_key as integer,",
				"          fecha_key as date,",
				"          nro_control as integer,",
				"          semana_gestacion as integer,",
				"          peso_madre_kg as decimal(5,2),",
				"          presion_arterial as string,",
				"          fuente_origen as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     recreate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          control_id,",
				"          nro_control,",
				"          semana_gestacion,",
				"          peso_madre_kg,",
				"          presion_arterial",
				"     )) ~> sink1"
			]
		}
	}
}
{
	"name": "df_silver_bja_controles_prenatales",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "BJA_bronce_controles_prenatales",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "BJA_silver_controles_prenatales",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "limpiezaSilver"
				},
				{
					"name": "aggregate1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          control_prenatal_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          semana_gestacion as string,",
				"          peso_madre_kg as string,",
				"          presion_arterial as string,",
				"          resultado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 derive(fecha_control = iif(instr(fecha_control, '-') == 5, toDate(fecha_control, 'yyyy-MM-dd'), toDate(fecha_control, 'dd-MM-yyyy')),",
				"          semana_gestacion = toInteger(semana_gestacion)) ~> limpiezaSilver",
				"limpiezaSilver aggregate(groupBy(control_prenatal_id),",
				"     ci_beneficiaria = first(ci_beneficiaria),",
				"          establecimiento_id = first(establecimiento_id),",
				"          nro_control = first(nro_control),",
				"          fecha_control = first(fecha_control),",
				"          semana_gestacion = first(semana_gestacion),",
				"          peso_madre_kg = first(peso_madre_kg),",
				"          presion_arterial = first(presion_arterial),",
				"          resultado = first(resultado)) ~> aggregate1",
				"aggregate1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          control_prenatal_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          semana_gestacion as string,",
				"          peso_madre_kg as string,",
				"          presion_arterial as string,",
				"          resultado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}
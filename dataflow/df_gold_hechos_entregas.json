{
	"name": "df_gold_hechos_entregas",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "SUP_silver_entregas",
						"type": "DatasetReference"
					},
					"name": "importarDatosDeSUPsilverEntregas"
				},
				{
					"dataset": {
						"referenceName": "SUP_silver_boletas",
						"type": "DatasetReference"
					},
					"name": "importarDatosDeSupSilverBoletas"
				},
				{
					"dataset": {
						"referenceName": "SUP_silver_catalogo_paquetes",
						"type": "DatasetReference"
					},
					"name": "ImportarDatosDeSUPsilveCatalogoPaquetes"
				},
				{
					"dataset": {
						"referenceName": "oro_Dim_Persona",
						"type": "DatasetReference"
					},
					"name": "OroDimPersona"
				},
				{
					"dataset": {
						"referenceName": "oro_Dim_Establecimiento",
						"type": "DatasetReference"
					},
					"name": "OroDimEstablecimiento"
				},
				{
					"dataset": {
						"referenceName": "oro_Dim_Paquete",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "oro_Hechos_Entregas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				},
				{
					"name": "join1"
				},
				{
					"name": "join2"
				},
				{
					"name": "join3"
				},
				{
					"name": "join4"
				},
				{
					"name": "join5"
				},
				{
					"name": "select2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          entrega_id as string,",
				"          boleta_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          paquete_id as string,",
				"          paquete_nombre as string,",
				"          fecha_entrega as date,",
				"          lote_produccion as string,",
				"          peso_paquete_kg as decimal(5,2),",
				"          fecha_proxima_entrega as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> importarDatosDeSUPsilverEntregas",
				"source(output(",
				"          boleta_id as string,",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          nro_boleta as string,",
				"          fecha_emision as date,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> importarDatosDeSupSilverBoletas",
				"source(output(",
				"          paquete_id as string,",
				"          nombre_paquete as string,",
				"          contenido_detalle as string,",
				"          costo_estimado_bs as decimal(18,2)",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> ImportarDatosDeSUPsilveCatalogoPaquetes",
				"source(output(",
				"          id as integer,",
				"          ci as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          fecha_nacimiento as date,",
				"          genero as string,",
				"          estado_civil as string,",
				"          ci_conyuge as string,",
				"          numero_hijos as integer,",
				"          ci_padre as string,",
				"          ci_madre as string,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          municipio_residencia as string,",
				"          fecha_emision as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> OroDimPersona",
				"source(output(",
				"          establecimiento_key as integer,",
				"          establecimiento_id as string,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> OroDimEstablecimiento",
				"source(output(",
				"          paquete_key as integer,",
				"          paquete_id as string,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as decimal(5,2),",
				"          costo_estimado_bs as decimal(10,2)",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"join5 derive(programa = 'SUP',",
				"          fecha_key = fecha_entrega,",
				"          cantidad_entrega = 1) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          entrega_id,",
				"          boleta_id = importarDatosDeSUPsilverEntregas@boleta_id,",
				"          fecha_proxima_entrega,",
				"          persona_key = id,",
				"          establecimiento_key,",
				"          paquete_key,",
				"          lote_produccion,",
				"          peso_paquete_kg,",
				"          fecha_key = fecha_entrega",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"importarDatosDeSUPsilverEntregas, importarDatosDeSupSilverBoletas join(importarDatosDeSUPsilverEntregas@boleta_id == importarDatosDeSupSilverBoletas@boleta_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1, ImportarDatosDeSUPsilveCatalogoPaquetes join(importarDatosDeSUPsilverEntregas@paquete_id == ImportarDatosDeSUPsilveCatalogoPaquetes@paquete_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join2",
				"select2, OroDimPersona join(ci_beneficiaria == ci,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join3",
				"join3, OroDimEstablecimiento join(importarDatosDeSUPsilverEntregas@establecimiento_id == OroDimEstablecimiento@establecimiento_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join4",
				"join4, source1 join(paquete_nombre == source1@nombre,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join5",
				"join2 select(mapColumn(",
				"          entrega_id,",
				"          boleta_id = importarDatosDeSUPsilverEntregas@boleta_id,",
				"          ci_beneficiaria = importarDatosDeSUPsilverEntregas@ci_beneficiaria,",
				"          establecimiento_id,",
				"          paquete_nombre,",
				"          fecha_entrega,",
				"          lote_produccion,",
				"          peso_paquete_kg,",
				"          fecha_proxima_entrega",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          entrega_id as string,",
				"          boleta_id as string,",
				"          persona_key as integer,",
				"          establecimiento_key as integer,",
				"          paquete_key as integer,",
				"          fecha_key as date,",
				"          lote_produccion as string,",
				"          peso_paquete_kg as decimal(5,2),",
				"          fecha_proxima_entrega as date",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          entrega_id,",
				"          boleta_id,",
				"          persona_key,",
				"          establecimiento_key,",
				"          paquete_key,",
				"          fecha_key,",
				"          lote_produccion,",
				"          peso_paquete_kg,",
				"          fecha_proxima_entrega",
				"     )) ~> sink1"
			]
		}
	}
}
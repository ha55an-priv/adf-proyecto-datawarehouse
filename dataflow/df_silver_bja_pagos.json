{
	"name": "df_silver_bja_pagos",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "BJA_bronce_pagos",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "BJA_silver_pagos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "limpiezaSilver"
				},
				{
					"name": "aggregate1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id as integer,",
				"          pago_id as string,",
				"          ci_beneficiaria as string,",
				"          concepto_pago as string,",
				"          monto_bs as string,",
				"          fecha_pago as string,",
				"          estado_pago as string,",
				"          canal_pago as string,",
				"          nro_comprobante as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 derive(monto_bs = toDecimal(iif(isNull(monto_bs) || monto_bs == '', '0.00', toString(monto_bs)), 5, 2),",
				"          fecha_pago = toDate(fecha_pago, 'yyyy-MM-dd'),",
				"          concepto_pago = iif(isNull(concepto_pago), 'No Especificado', trim(concepto_pago)),",
				"          estado_pago = iif(isNull(estado_pago), 'Desconocido', trim(estado_pago)),",
				"          canal_pago = iif(isNull(canal_pago), 'No Especificado', trim(canal_pago)),",
				"          nro_comprobante = iif(isNull(nro_comprobante), 'S/N', trim(nro_comprobante))) ~> limpiezaSilver",
				"limpiezaSilver aggregate(groupBy(pago_id),",
				"     ci_beneficiaria = first(ci_beneficiaria),",
				"          concepto_pago = first(concepto_pago),",
				"          monto_bs = first(monto_bs),",
				"          fecha_pago = first(fecha_pago),",
				"          estado_pago = first(estado_pago),",
				"          canal_pago = first(canal_pago),",
				"          nro_comprobante = first(nro_comprobante)) ~> aggregate1",
				"aggregate1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          pago_id as string,",
				"          ci_beneficiaria as string,",
				"          concepto_pago as string,",
				"          monto_bs as decimal(5,2),",
				"          fecha_pago as date,",
				"          estado_pago as string,",
				"          canal_pago as string,",
				"          nro_comprobante as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}
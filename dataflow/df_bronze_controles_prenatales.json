{
	"name": "df_bronze_controles_prenatales",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bja_controles_prenatales_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_controles_prenatales",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          control_prenatal_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          nro_control as string,",
				"          fecha_control as string,",
				"          semana_gestacion as string,",
				"          peso_madre_kg as string,",
				"          presion_arterial as string,",
				"          resultado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(control_prenatal_id = toString(control_prenatal_id),",
				"          ci_beneficiaria = trim(ci_beneficiaria),",
				"          establecimiento_id = toString(establecimiento_id),",
				"          nro_control = toInteger(nro_control),",
				"          fecha_control = toDate(     iif(         instr(toString(fecha_control), '/') > 0,         toTimestamp(toString(fecha_control), 'dd/MM/yyyy'),         toTimestamp(toString(fecha_control), 'yyyy-MM-dd')     ) ),",
				"          semana_gestacion = toInteger(semana_gestacion),",
				"          peso_madre_kg = iif(isNull(peso_madre_kg) || peso_madre_kg == '', toDecimal(0, 5, 2), toDecimal(peso_madre_kg, 5, 2)),",
				"          presion_arterial = trim(presion_arterial),",
				"          origen_sistema = 'BJA',",
				"          resultado = case(     isNull(resultado) || trim(resultado) == '', 'No Especificado',     regexMatch(lower(trim(resultado)), '.*norm.*|.*nomr.*|.*noor.*'), 'Normal',     regexMatch(lower(trim(resultado)), '.*mod.*'), 'Riesgo Moderado',     regexMatch(lower(trim(resultado)), '.*alt.*'), 'Riesgo Alto',     regexMatch(lower(trim(resultado)), '.*baj.*'), 'Riesgo Bajo',     'Otro' )) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          control_prenatal_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          nro_control as integer,",
				"          fecha_control as date,",
				"          semana_gestacion as integer,",
				"          peso_madre_kg as decimal(5,2),",
				"          presion_arterial as string,",
				"          origen_sistema as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          control_prenatal_id,",
				"          ci_beneficiaria,",
				"          establecimiento_id,",
				"          nro_control,",
				"          fecha_control,",
				"          semana_gestacion,",
				"          peso_madre_kg,",
				"          presion_arterial,",
				"          origen_sistema",
				"     )) ~> sink1"
			]
		}
	}
}
{
	"name": "df_bronze_sup_entregas",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "sup_entregas_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_sup_entregas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          entrega_id as string,",
				"          boleta_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          paquete_id as string,",
				"          paquete_nombre as string,",
				"          fecha_entrega as string,",
				"          lote_produccion as string,",
				"          peso_paquete_kg as string,",
				"          fecha_proxima_entrega as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(entrega_id = toString(entrega_id),",
				"          boleta_id = toString(boleta_id),",
				"          ci_beneficiaria = trim(ci_beneficiaria),",
				"          establecimiento_id = toInteger(establecimiento_id),",
				"          paquete_nombre = trim(paquete_nombre),",
				"          paquete_id = toString(paquete_id),",
				"          fecha_entrega = toDate(iif(instr(toString(fecha_entrega), '/') > 0, toTimestamp(toString(fecha_entrega), 'dd/MM/yyyy'), toTimestamp(toString(fecha_entrega), 'yyyy-MM-dd'))),",
				"          lote_produccion = iif(isNull(lote_produccion) || trim(lote_produccion) == '', 'Sin Lote', trim(lote_produccion)),",
				"          peso_paquete_kg = iif(isNull(peso_paquete_kg) || peso_paquete_kg == '', toDecimal(0, 5, 2), toDecimal(peso_paquete_kg, 5, 2)),",
				"          fecha_proxima_entrega = toDate(iif(instr(toString(fecha_proxima_entrega), '/') > 0, toTimestamp(toString(fecha_proxima_entrega), 'dd/MM/yyyy'), toTimestamp(toString(fecha_proxima_entrega), 'yyyy-MM-dd'))),",
				"          origen_sistema = 'SUP') ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          entrega_id as string,",
				"          boleta_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          paquete_id as string,",
				"          paquete_nombre as string,",
				"          fecha_entrega as date,",
				"          lote_produccion as string,",
				"          peso_paquete_kg as decimal(5,2),",
				"          fecha_proxima_entrega as date,",
				"          origen_sistema as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          entrega_id,",
				"          boleta_id,",
				"          ci_beneficiaria,",
				"          establecimiento_id,",
				"          paquete_id,",
				"          paquete_nombre,",
				"          fecha_entrega,",
				"          lote_produccion,",
				"          peso_paquete_kg,",
				"          fecha_proxima_entrega,",
				"          origen_sistema",
				"     )) ~> sink1"
			]
		}
	}
}
{
	"name": "df_bronce_segip",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "segip_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "SEGIP_bronce",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          ci as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          fecha_nacimiento as string,",
				"          genero as string,",
				"          estado_civil as string,",
				"          ci_conyuge as string,",
				"          numero_hijos as string,",
				"          ci_padre as string,",
				"          ci_madre as string,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          municipio_residencia as string,",
				"          fecha_emision as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id as integer,",
				"          ci as string,",
				"          nombre as string,",
				"          paterno as string,",
				"          materno as string,",
				"          fecha_nacimiento as string,",
				"          genero as string,",
				"          estado_civil as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}
{
	"name": "df_gold_dim_paquete",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "SUP_silver_catalogo_paquetes",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "oro_Dim_Paquete",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          paquete_id as string,",
				"          nombre_paquete as string,",
				"          contenido_detalle as string,",
				"          costo_estimado_bs as decimal(18,2)",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 select(mapColumn(",
				"          paquete_id,",
				"          nombre_paquete,",
				"          contenido_detalle,",
				"          costo_estimado_bs",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          paquete_key as integer,",
				"          paquete_id as string,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as decimal(5,2),",
				"          costo_estimado_bs as decimal(10,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          paquete_id,",
				"          nombre = nombre_paquete,",
				"          contenido = contenido_detalle,",
				"          costo_estimado_bs",
				"     )) ~> sink1"
			]
		}
	}
}
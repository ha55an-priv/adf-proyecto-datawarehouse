{
	"name": "df_bronze_inscripciones_programas",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "sup_inscripciones_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_inscripciones_programas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          inscripcion_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          fecha_inscripcion as string,",
				"          semana_gestacion as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(inscripcion_id = toString(inscripcion_id),",
				"          ci_beneficiaria = trim(ci_beneficiaria),",
				"          establecimiento_id = toInteger(establecimiento_id),",
				"          fecha_inscripcion = toDate(fecha_inscripcion, 'yyyy-MM-dd'),",
				"          semana_gestacion = toInteger(semana_gestacion),",
				"          estado = trim(estado),",
				"          origen_sistema = 'SUBSIDIO') ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          inscripcion_id as string,",
				"          ci_beneficiaria as string,",
				"          fecha_inscripcion as date,",
				"          origen_sistema as string,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          inscripcion_id,",
				"          ci_beneficiaria,",
				"          fecha_inscripcion,",
				"          origen_sistema,",
				"          estado",
				"     )) ~> sink1"
			]
		}
	}
}
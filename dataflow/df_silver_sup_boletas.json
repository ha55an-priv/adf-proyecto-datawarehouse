{
	"name": "df_silver_sup_boletas",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "SUP_bronce_boletas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "SUP_silver_boletas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "limpiezaSilver"
				},
				{
					"name": "aggregate1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          boleta_id as integer,",
				"          control_id as integer,",
				"          ci_beneficiaria as string,",
				"          nro_boleta as string,",
				"          fecha_emision as date,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 derive(boleta_id = toInteger(boleta_id),",
				"          control_id = toInteger(control_id),",
				"          ci_beneficiaria = trim(ci_beneficiaria),",
				"          nro_boleta = trim(nro_boleta),",
				"          fecha_emision = toDate(toString(fecha_emision), 'yyyy-MM-dd'),",
				"          estado = iif(isNull(estado) || estado == '', 'No Especificado', trim(estado))) ~> limpiezaSilver",
				"limpiezaSilver aggregate(groupBy(boleta_id),",
				"     control_id = first(control_id),",
				"          ci_beneficiaria = first(ci_beneficiaria),",
				"          nro_boleta = first(nro_boleta),",
				"          fecha_emision = first(fecha_emision),",
				"          estado = first(estado)) ~> aggregate1",
				"aggregate1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          boleta_id as string,",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          nro_boleta as string,",
				"          fecha_emision as date,",
				"          estado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}
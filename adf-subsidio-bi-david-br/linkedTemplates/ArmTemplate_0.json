{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Nombre de instancia de Data Factory",
			"defaultValue": "adf-subsidio-bi-david-br"
		},
		"ls_datalake_subsidio_accountKey": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"accountKey\"de \"ls_datalake_subsidio\""
		},
		"ls_sql_subsidio_password": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"password\"de \"ls_sql_subsidio\""
		},
		"ls_datalake_subsidio_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://stsubsidiodavidbrazil.dfs.core.windows.net/"
		},
		"ls_sql_subsidio_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqlsrv-subsidio-david-v2.database.windows.net"
		},
		"ls_sql_subsidio_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "db-subsidio-bi"
		},
		"ls_sql_subsidio_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "userSisGer"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/ls_datalake_subsidio')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureBlobFS",
				"typeProperties": {
					"url": "[parameters('ls_datalake_subsidio_properties_typeProperties_url')]",
					"accountKey": {
						"type": "SecureString",
						"value": "[parameters('ls_datalake_subsidio_accountKey')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/ls_sql_subsidio')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureSqlDatabase",
				"typeProperties": {
					"server": "[parameters('ls_sql_subsidio_properties_typeProperties_server')]",
					"database": "[parameters('ls_sql_subsidio_properties_typeProperties_database')]",
					"encrypt": "mandatory",
					"trustServerCertificate": false,
					"authenticationType": "SQL",
					"userName": "[parameters('ls_sql_subsidio_properties_typeProperties_userName')]",
					"password": {
						"type": "SecureString",
						"value": "[parameters('ls_sql_subsidio_password')]"
					}
				}
			},
			"dependsOn": []
		},

						}
					],
					"transformations": [
						{
							"name": "derivedColumn1"
						}
					],
					"scriptLines": [
						"source(output(",
						"          ci as string,",
						"          nombres as string,",
						"          apellido_paterno as string,",
						"          apellido_materno as string,",
						"          fecha_nacimiento as string,",
						"          genero as string,",
						"          estado_civil as string,",
						"          ci_conyuge as string,",
						"          numero_hijos as string,",
						"          ci_padre as string,",
						"          ci_madre as string,",
						"          profesion as string,",
						"          nivel_estudios as string,",
						"          municipio_residencia as string,",
						"          fecha_emision as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> source1",
						"source1 derive(ci = trim(ci),",
						"          nombres = trim(replace(replace(replace(replace(replace(replace(nombres, 'Ã¡', 'á'), 'Ã©', 'é'), 'Ã­', 'í'), 'Ã³', 'ó'), 'Ãº', 'ú'), 'Ã±', 'ñ')),",
						"          apellido_paterno = trim(replace(replace(replace(replace(replace(replace(apellido_paterno, 'Ã¡', 'á'), 'Ã©', 'é'), 'Ã­', 'í'), 'Ã³', 'ó'), 'Ãº', 'ú'), 'Ã±', 'ñ')),",
						"          apellido_materno = trim(replace(replace(replace(replace(replace(replace(apellido_materno, 'Ã¡', 'á'), 'Ã©', 'é'), 'Ã­', 'í'), 'Ã³', 'ó'), 'Ãº', 'ú'), 'Ã±', 'ñ')),",
						"          genero = trim(genero),",
						"          estado_civil = case(estado_civil == 'Soltera', 'Soltero', estado_civil == 'Casada', 'Casado', estado_civil == 'Viuda', 'Viudo', estado_civil == 'Divorciada', 'Divorciado', trim(estado_civil)),",
						"          municipio_residencia = trim(replace(replace(replace(replace(replace(replace(municipio_residencia, 'Ã¡', 'á'), 'Ã©', 'é'), 'Ã­', 'í'), 'Ã³', 'ó'), 'Ãº', 'ú'), 'Ã±', 'ñ')),",
						"          fecha_nacimiento = toDate(fecha_nacimiento, 'yyyy-MM-dd'),",
						"          fecha_emision = toDate(fecha_emision, 'yyyy-MM-dd'),",
						"          ci_conyuge = iif(isNull(ci_conyuge) || ci_conyuge == '', toString(null()), trim(ci_conyuge)),",
						"          numero_hijos = iif(isNull(numero_hijos) || numero_hijos == '', 0, toInteger(numero_hijos)),",
						"          ci_padre = iif(isNull(ci_padre) || ci_padre == '', toString(null()), trim(ci_padre)),",
						"          ci_madre = iif(isNull(ci_madre) || ci_madre == '', toString(null()), trim(ci_madre)),",
						"          profesion = case(     isNull(profesion) || profesion == '', 'Sin Profesión',     trim(replace(replace(replace(replace(replace(replace(profesion, 'Ã¡', 'á'), 'Ã©', 'é'), 'Ã­', 'í'), 'Ã³', 'ó'), 'Ãº', 'ú'), 'Ã±', 'ñ')) ),",
						"          nivel_estudios = case(     isNull(nivel_estudios) || nivel_estudios == '', 'No Especificado',     trim(nivel_estudios) )) ~> derivedColumn1",
						"derivedColumn1 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     input(",
						"          ci as string,",
						"          nombres as string,",
						"          apellido_paterno as string,",
						"          apellido_materno as string,",
						"          fecha_nacimiento as date,",
						"          genero as string,",
						"          estado_civil as string,",
						"          ci_conyuge as string,",
						"          numero_hijos as integer,",
						"          ci_padre as string,",
						"          ci_madre as string,",
						"          profesion as string,",
						"          nivel_estudios as string,",
						"          municipio_residencia as string,",
						"          fecha_emision as date",
						"     ),",
						"     deletable:false,",
						"     insertable:true,",
						"     updateable:false,",
						"     upsertable:false,",
						"     format: 'table',",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     errorHandlingOption: 'stopOnFirstError',",
						"     mapColumn(",
						"          ci,",
						"          nombres,",
						"          apellido_paterno,",
						"          apellido_materno,",
						"          fecha_nacimiento,",
						"          genero,",
						"          estado_civil,",
						"          ci_conyuge,",
						"          numero_hijos,",
						"          ci_padre,",
						"          ci_madre,",
						"          profesion,",
						"          nivel_estudios,",
						"          municipio_residencia,",
						"          fecha_emision",
						"     )) ~> sink1"
					]
				}
			},
			"dependsOn": []
		},

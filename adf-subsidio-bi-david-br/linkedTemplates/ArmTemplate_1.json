{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Nombre de instancia de Data Factory",
			"defaultValue": "adf-subsidio-bi-david-br"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/silver_controles_pediatricos')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "ls_sql_subsidio",
					"type": "LinkedServiceReference"
				},
				"folder": {
					"name": "silver"
				},
				"annotations": [],
				"type": "AzureSqlTable",
				"schema": [
					{
						"name": "control_pediatrico_id",
						"type": "varchar"
					},
					{
						"name": "ci_nino",
						"type": "varchar"
					},
					{
						"name": "ci_madre",
						"type": "varchar"
					},
					{
						"name": "establecimiento_id",
						"type": "varchar"
					},
					{
						"name": "nro_control",
						"type": "int",
						"precision": 10
					},
					{
						"name": "fecha_control",
						"type": "date"
					},
					{
						"name": "peso_nino_kg",
						"type": "decimal",
						"precision": 5,
						"scale": 2
					},
					{
						"name": "talla_nino_cm",
						"type": "decimal",
						"precision": 5,
						"scale": 2
					},
					{
						"name": "vacuna_aplicada",
						"type": "varchar"
					}
				],
				"typeProperties": {
					"schema": "silver",
					"table": "controles_pediatricos"
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/silver_partos')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "ls_sql_subsidio",
					"type": "LinkedServiceReference"
				},
				"folder": {
					"name": "silver"
				},
				"annotations": [],
				"type": "AzureSqlTable",
				"schema": [
					{
						"name": "parto_id",
						"type": "varchar"
					},
					{
						"name": "inscripcion_id",
						"type": "varchar"
					},
					{
						"name": "fecha_parto",
						"type": "date"
					},
					{
						"name": "tipo_parto",
						"type": "varchar"
					},
					{
						"name": "ci_hijo",
						"type": "varchar"
					}
				],
				"typeProperties": {
					"schema": "silver",
					"table": "partos"
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/silver_inscripciones_programas')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "ls_sql_subsidio",
					"type": "LinkedServiceReference"
				},
				"folder": {
					"name": "silver"
				},
				"annotations": [],
				"type": "AzureSqlTable",
				"schema": [
					{
						"name": "inscripcion_id",
						"type": "varchar"
					},
					{
						"name": "ci_beneficiaria",
						"type": "varchar"
					},
					{
						"name": "fecha_inscripcion",
						"type": "date"
					},
					{
						"name": "origen_sistema",
						"type": "varchar"
					},
					{
						"name": "estado",
						"type": "varchar"
					}
				],
				"typeProperties": {
					"schema": "silver",
					"table": "inscripciones_programas"
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/df_bronze_catalogo_paquetes')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"folder": {
					"name": "bronze"
				},
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "sup_catalogo_paquetes_csv",
								"type": "DatasetReference"
							},
							"name": "source1"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "silver_catalogo_paquetes",
								"type": "DatasetReference"
							},
							"name": "sink1"
						}
					],
					"transformations": [
						{
							"name": "derivedColumn1"
						}
					],
					"scriptLines": [
						"source(output(",
						"          paquete_id as string,",
						"          nombre as string,",
						"          contenido as string,",
						"          peso_estandar_kg as string,",
						"          costo_estimado_bs as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> source1",
						"source1 derive(paquete_id = paquete_id,",
						"          nombre_paquete = trim(replace(replace(replace(replace(replace(replace(nombre, 'Ã¡', 'á'), 'Ã©', 'é'), 'Ã­', 'í'), 'Ã³', 'ó'), 'Ãº', 'ú'), 'Ã±', 'ñ')),",
						"          contenido_detalle = trim(replace(replace(replace(replace(replace(replace(contenido, 'Ã¡', 'á'), 'Ã©', 'é'), 'Ã­', 'í'), 'Ã³', 'ó'), 'Ãº', 'ú'), 'Ã±', 'ñ')),",
						"          peso_estandar_kg = toDecimal(peso_estandar_kg, 5, 2),",
						"          costo_estimado_bs = toDecimal(costo_estimado_bs, 18, 2)) ~> derivedColumn1",
						"derivedColumn1 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     input(",
						"          paquete_id as string,",
						"          nombre_paquete as string,",
						"          contenido_detalle as string,",
						"          costo_estimado_bs as decimal(18,2)",
						"     ),",
						"     deletable:false,",
						"     insertable:true,",
						"     updateable:false,",
						"     upsertable:false,",
						"     format: 'table',",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     errorHandlingOption: 'stopOnFirstError',",
						"     mapColumn(",
						"          paquete_id,",
						"          nombre_paquete,",
						"          contenido_detalle,",
						"          costo_estimado_bs",
						"     )) ~> sink1"
					]
				}
			},
			"dependsOn": []
		}
	]
}